# ════════════════════════════════════════════════════════════════
# EduTECH ESEN — Variables de entorno (ejemplo)
# Copia este archivo a .env (local) o configúralas en Vercel → Settings → Environment Variables
# ════════════════════════════════════════════════════════════════

# ── Firebase (OBLIGATORIO — base de datos Firestore) ────────────
# Obtén estas credenciales desde Firebase Console:
#   1. https://console.firebase.google.com/ → crea/selecciona proyecto
#   2. Project Settings (⚙️) → Service Accounts tab → "Generate new private key"
#   3. Descarga el JSON y copia estos 3 valores:
FIREBASE_PROJECT_ID="tu-proyecto-firebase"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@tu-proyecto.iam.gserviceaccount.com"
# La private key viene con \n literales — pégala COMO ESTÁ en Vercel
# (Vercel preserva los \n; el código los decodifica automáticamente)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
# Opcional — solo si usas Realtime Database:
FIREBASE_DATABASE_URL=""

# ── JWT (OBLIGATORIO en producción) ─────────────────────────────
# Secreto para firmar los tokens JWT de sesión.
# Genera uno con: openssl rand -hex 32
JWT_SECRET="cambia-esto-por-una-cadena-aleatoria-de-64-caracteres-hex"

# ── Seed (OBLIGATORIO) ──────────────────────────────────────────
# Secreto para autorizar el endpoint de inicialización /api/seed.
# Genera uno con: openssl rand -hex 32
# Requerido en el header x-seed-secret al llamar /api/seed
SEED_SECRET="cambia-esto-por-otra-cadena-aleatoria"

# ── OPCIONALES: servicio realtime (WebSocket) ──────────────────
# Si despliegas el mini-servicio realtime en Railway/Render/Fly.io,
# configura estas variables. Si no, déjalas vacías (realtime se desactiva).
REALTIME_INTERNAL_URL=""
REALTIME_INTERNAL_TOKEN=""

# URL pública del WebSocket (para el navegador). Vacío = realtime desactivado.
# Ej: wss://tu-realtime-app.up.railway.app
NEXT_PUBLIC_REALTIME_URL=""
